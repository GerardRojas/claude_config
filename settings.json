      "Bash(npx supabase db reset*)",
      "Bash(psql*)",
      "PowerShell(psql*)",
      "Bash(*DROP TABLE*)",
      "Bash(*DROP DATABASE*)",
      "Bash(*TRUNCATE*)",
      "Bash(*DELETE FROM*)"
