      "Bash(node *)",
      "Bash(node_modules/.bin/*)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(py *)",
      "Bash(pip *)",
      "Bash(pytest*)",
      "Bash(uvicorn *)",
      "Bash(.venv/Scripts/*)",
      "Bash(./.venv/Scripts/*)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(ls*)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(sed *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(command -v *)",
      "Bash(curl *)",
      "Bash(netstat*)",
      "PowerShell(*)",
      "Read(//**)",
      "Edit(//**)",
